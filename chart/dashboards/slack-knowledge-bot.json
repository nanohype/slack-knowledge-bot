{
  "uid": "slack-knowledge-bot",
  "title": "SlackKnowledgeBot",
  "tags": ["protohype", "slack-knowledge-bot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      },
      {
        "name": "environment",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(slack_knowledge_bot_query_latency_ms_bucket, deployment_environment)",
        "current": {
          "text": "production",
          "value": "production"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Slack query — latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(slack_knowledge_bot_query_latency_ms_bucket{deployment_environment=\"$environment\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(slack_knowledge_bot_query_latency_ms_bucket{deployment_environment=\"$environment\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(slack_knowledge_bot_query_latency_ms_bucket{deployment_environment=\"$environment\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 2,
      "title": "Slack query — rate by outcome",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(slack_knowledge_bot_query_total{deployment_environment=\"$environment\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 3,
      "title": "Bedrock — calls per second",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum by (model) (rate(slack_knowledge_bot_bedrock_calls_total{deployment_environment=\"$environment\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 4,
      "title": "Bedrock — errors per second",
      "type": "timeseries",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(slack_knowledge_bot_llm_error_total{deployment_environment=\"$environment\"}[5m]))",
          "legendFormat": "errors/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.0167}]}}}
    },
    {
      "id": 5,
      "title": "WorkOS identity — lookups + cache",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(slack_knowledge_bot_identity_lookup_total{deployment_environment=\"$environment\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 6,
      "title": "Audit pipeline — total loss",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(slack_knowledge_bot_audit_total_loss_total{deployment_environment=\"$environment\"}[5m]))",
          "legendFormat": "total loss / s",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0}]}}}
    },
    {
      "id": 7,
      "title": "Audit DLQ depth (cloudwatch-exporter required)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "max by (queue_name) (aws_sqs_approximate_number_of_messages_visible{queue_name=~\"slack-knowledge-bot-audit-dlq-.*\"})",
          "legendFormat": "{{queue_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 8,
      "title": "Rate limiter — outcomes/s",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 8},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(slack_knowledge_bot_ratelimit_total{deployment_environment=\"$environment\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    }
  ]
}
